---
# Kubernetes Secret — Flask application secret key
# Generated by Ansible from vault.yml — do not edit manually
apiVersion: v1
kind: Secret
metadata:
  name: flask-secret
  namespace: {{ app_namespace }}
  labels:
    app: voting-app
    managed-by: ansible
type: Opaque
stringData:
  FLASK_SECRET_KEY: "{{ flask_secret_key }}"
